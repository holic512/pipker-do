# AI 索引: backend 本地环境变量示例，微信小程序密钥只通过本地环境变量注入。
WECHAT_MINIAPP_APP_ID=wx_your_miniapp_appid
WECHAT_MINIAPP_APP_SECRET=replace_with_your_wechat_miniapp_secret
WECHAT_MINIAPP_CONNECT_TIMEOUT=3s
WECHAT_MINIAPP_READ_TIMEOUT=5s

# 可选: 本地文件存储覆盖
STORAGE_LOCAL_BASE_PATH=./file
STORAGE_LOCAL_PUBLIC_BASE_URL=http://localhost:8080/static/files
